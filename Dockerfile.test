FROM node:22-slim

# 安装最小化的系统依赖（Electron/VS Code 必需）
RUN apt-get update -qq && \
    apt-get install -y -qq --no-install-recommends \
    libgtk-3-0 libgbm1 libnss3 libxss1 libxtst6 libsecret-1-0 libasound2 xvfb xauth git ca-certificates && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

CMD ["xvfb-run", "--server-args=-screen 0 1280x720x24", "npx", "vscode-test"]
