{
  "publisher": "mossgowild",
  "name": "quota-monitor",
  "displayName": "Quota Monitor",
  "description": "Monitor provider usage quotas in a beautiful panel view. Supports Google Antigravity, GitHub Copilot, Gemini CLI, Zhipu AI, Z.AI, and Kimi Code.",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mossgowild/vscode-quota-monitor.git"
  },
  "bugs": {
    "url": "https://github.com/mossgowild/vscode-quota-monitor/issues"
  },
  "homepage": "https://github.com/mossgowild/vscode-quota-monitor#readme",
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.cjs",
  "engines": {
    "vscode": "^1.99.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "title": "Quota Monitor",
      "properties": {
        "quotaMonitor.providers": {
          "type": "object",
          "default": {},
          "markdownDescription": "Configured provider accounts. Use the **Manage Accounts** command to add, edit, or remove accounts interactively.",
          "additionalProperties": {
            "type": "array",
            "markdownDescription": "List of accounts for this provider",
            "items": {
              "type": "object",
              "properties": {
                "credential": {
                  "type": "string",
                  "markdownDescription": "Authentication credentials. OAuth tokens for OAuth providers, or API keys for API key providers"
                },
                "name": {
                  "type": "string",
                  "markdownDescription": "Display name for this account (shown in the quota panel)"
                }
              },
              "required": [
                "credential"
              ]
            }
          },
          "propertyNames": {
            "enum": [
              "claudeCode",
              "deepSeek",
              "githubCopilot",
              "googleAntigravity",
              "googleGemini",
              "kimiCode",
              "moonshot",
              "openRouter",
              "openaiCodex",
              "siliconFlow",
              "zai",
              "zhipu"
            ],
            "enumDescriptions": [
              "Claude Code",
              "DeepSeek",
              "GitHub Copilot",
              "Google Antigravity",
              "Google Gemini",
              "Kimi Code",
              "Moonshot AI",
              "OpenRouter",
              "OpenAI Codex",
              "SiliconFlow",
              "Z.AI",
              "Zhipu AI"
            ]
          }
        },
        "quotaMonitor.autoRefreshEnabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Automatically refresh quota data at the specified interval"
        },
        "quotaMonitor.autoRefreshIntervalMs": {
          "type": "number",
          "default": 180000,
          "markdownDescription": "Refresh interval in milliseconds. Default: 180000 (3 minutes). Minimum recommended: 60000 (1 minute)"
        }
      }
    },
    "commands": [
      {
        "command": "quotaMonitor.focus",
        "title": "Show Quota Monitor",
        "category": "Quota Monitor"
      },
      {
        "command": "quotaMonitor.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "quotaMonitor.settings",
        "title": "Settings",
        "icon": "$(gear)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "quotaMonitor-sidebar",
          "title": "Quota",
          "icon": "images/icon.svg"
        }
      ]
    },
    "views": {
      "quotaMonitor-sidebar": [
        {
          "type": "webview",
          "id": "quotaMonitor.usageView",
          "name": "Quota",
          "icon": "images/icon.svg",
          "contextualTitle": "Quota"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "quotaMonitor.refresh",
          "when": "view == quotaMonitor.usageView",
          "group": "navigation@1"
        },
        {
          "command": "quotaMonitor.settings",
          "when": "view == quotaMonitor.usageView",
          "group": "navigation@2"
        }
      ]
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "build:test": "vite build --config vite.config.test.ts",
    "test": "npm run build:test && docker compose run --rm test",
    "test:build": "npm run build:test && docker compose run --build --rm test",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/sinon": "^21.0.0",
    "@types/vscode": "^1.99.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^8.56.0",
    "mocha": "^11.7.5",
    "reactive-vscode": "^1.0.0-beta.2",
    "sinon": "^21.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
